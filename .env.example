# Copy this file to .env and fill in your credentials
# NEVER commit .env to version control

# The Gmail address used to SEND emails from the contact form
MAIL_USER=your-gmail-address@gmail.com

# A Gmail App Password (NOT your regular Gmail password)
# See the README for instructions on generating one
MAIL_PASS=your-16-character-app-password

# Optional: change the port the server runs on (default: 3000)
PORT=3000
